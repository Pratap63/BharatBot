@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card shadow-lg border-0" style="max-width: 450px; width:100%;">
        <div class="card-body p-4 text-center">

            <h3 class="fw-bold mb-3">Reset Your Password 🔐</h3>
            <p class="text-muted mb-4">Choose how you want to reset your password.</p>

            <div class="d-grid gap-3">

                <a asp-action="ResetUsingLink"
                   class="btn btn-outline-primary btn-lg rounded-pill">
                    Reset Using Email Link
                </a>

                <a asp-action="ResetUsingOtp"
                   class="btn btn-outline-primary btn-lg rounded-pill">
                    Reset Using OTP
                </a>

            </div>

        </div>
    </div>
</div>
